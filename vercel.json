{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "ignoreCommand": "node -e \"const haystack = [process.env.VERCEL_PROJECT_PRODUCTION_URL, process.env.VERCEL_BRANCH_URL, process.env.VERCEL_URL].filter(Boolean).join(' ').toLowerCase(); process.exit(haystack.includes('api-server') ? 0 : 1)\"",
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm --filter @workspace/saju-web run build",
  "outputDirectory": "artifacts/saju-web/dist/public",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index"
    },
    {
      "source": "/:match*",
      "destination": "/index.html"
    }
  ]
}
