# Core app
APP_URL=http://localhost:3000
BASE_PATH=/
PORT=5001
WEB_PORT=3000

# Database
# Use a real runtime secret here. Do not commit your actual password.
# Supabase Session Pooler example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
# Local Postgres example:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/lucky_day_planner
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000

# Role management
ADMIN_EMAILS=
SUPER_ADMIN_EMAILS=your-email@example.com

# Optional SMTP for password reset emails
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Optional OIDC login
OIDC_CLIENT_ID=
OIDC_ISSUER_URL=https://replit.com/oidc

# Backward-compatible legacy OIDC vars
REPL_ID=
ISSUER_URL=

# Supabase auth
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
